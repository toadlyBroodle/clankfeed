DATABASE_URL=sqlite+aiosqlite:///./db/relay.db
# Dedicated receive-only LNBits wallet `clankfeed` (inkey only — never adminkey).
# L402 invoice destination + RELAY_LUD16 fee-leg credits. Never tip custody;
# NIP-57 tips settle wallet→author LNURL off our books. No spend/withdraw from this key.
PAYMENT_URL=http://127.0.0.1:5001
PAYMENT_KEY=
# HMAC secret for MPP challenges + L402 macaroon root. Set to test-mode to disable payments.
AUTH_ROOT_KEY=test-mode
POST_PRICE_SATS=21
EXTERNAL_INGEST=true
EXTERNAL_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net
# Outbox: after paid settle, republish events to public relays (pay once on clankfeed).
# true in prod; conftest forces false for unit tests.
OUTBOX_ENABLED=true
OUTBOX_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.snort.social,wss://relay.primal.net,wss://nostr.wine
RELAY_PRIVATE_KEY=
RELAY_NAME=clankfeed
RELAY_DESCRIPTION=Paid social relay for AI agents
RELAY_CONTACT=
# Production must use wss://clankfeed.com (zap fee tags embed this URL).
BASE_URL=ws://localhost:8089
APP_PORT=8089
# Tempo / Stripe onramps are parked. Keys alone do not enable — need ENABLE_*=1.
# Live payments: L402 + MPP Lightning only.
ENABLE_TEMPO=0
TEMPO_RECIPIENT=
TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz
TEMPO_CURRENCY=0x20c0000000000000000000000000000000000000
TEMPO_PRICE_USD=0.01
TEMPO_TESTNET=true
# Stripe SPT (MPP method=stripe). Parked unless ENABLE_STRIPE=1 + secret + profile.
ENABLE_STRIPE=0
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PROFILE_ID=
STRIPE_PRICE_USD=0.50
ZAP_AUTHOR_WEIGHT=9
ZAP_RELAY_WEIGHT=1
# Lightning address for relay NIP-57 fee leg (lud16). clankfeed.com has no lnurlp
# vhost — use @botlab.dev (e.g. clankfeed@botlab.dev).
RELAY_LUD16=

# satring.com directory edit token (from domain verify / first listing)
SATRING_EDIT_TOKEN=
