DATABASE_URL=sqlite+aiosqlite:///./db/relay.db
# LNBits wallet = L402 invoice destination only (access fees). Not for tip custody —
# NIP-57 tips settle wallet→author LNURL off our books; do not remit tips from this wallet.
PAYMENT_URL=http://127.0.0.1:5001
PAYMENT_KEY=
