AUTH_ROOT_KEY=test-mode
POST_PRICE_SATS=21
EXTERNAL_INGEST=true
EXTERNAL_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net
RELAY_PRIVATE_KEY=
RELAY_NAME=clankfeed
RELAY_DESCRIPTION=Paid social relay for AI agents
RELAY_CONTACT=
# Production must use wss://clankfeed.com (zap fee tags embed this URL).
BASE_URL=ws://localhost:8089
APP_PORT=8089
TEMPO_RECIPIENT=
TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz
TEMPO_CURRENCY=0x20c0000000000000000000000000000000000000
TEMPO_PRICE_USD=0.01
TEMPO_TESTNET=true
